# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_MARKET=US

# Spotify OAuth (for user login - enables audio features)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# Last.fm API (for track similarity - alternative to Spotify audio features)
# Get your API key from https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# Genius API (optional - for song context/lyrics info)
GENIUS_ACCESS_TOKEN=your_genius_token_here

# Server settings
PORT=8000
